ENDICNS

ok "Source files ready."

# ── 5. Build app bundle ───────────────────────────────────────────────────────
APP="$BDIR/Winshrink.app"
mkdir -p "$APP/Contents/MacOS" "$APP/Contents/Resources"
cp "$BDIR/Info.plist"      "$APP/Contents/Info.plist"
cp "$BDIR/Winshrink.icns"  "$APP/Contents/Resources/Winshrink.icns"

log "Compiling Winshrink.app (~20 seconds)..."
# Build the compiler argument list, injecting the right SDK when needed.
COMPILE_ARGS=(-O
    -framework Cocoa
    -framework ApplicationServices
    -framework Carbon
    -framework ServiceManagement
    "$BDIR/main.swift"
    -o "$APP/Contents/MacOS/Winshrink")

if [ -n "$COMPAT_SDK" ]; then
    COMPILE_ARGS=(-sdk "$COMPAT_SDK" "${COMPILE_ARGS[@]}")
fi

if [ -n "$XCODE_DEV" ]; then
    DEVELOPER_DIR="$XCODE_DEV" xcrun swiftc "${COMPILE_ARGS[@]}"
else
    xcrun swiftc "${COMPILE_ARGS[@]}"
fi

[ -f "$APP/Contents/MacOS/Winshrink" ] || { err "Compilation failed."; exit 1; }
chmod +x "$APP/Contents/MacOS/Winshrink"
ok "Compiled ✓"

# ── 6. Ad-hoc code-sign (needed for CGEventTap) ───────────────────────────────
log "Ad-hoc code signing..."
codesign --force --deep --sign - "$APP" && ok "Signed ✓" || warn "Signing skipped."

# ── 7. Install to /Applications ──────────────────────────────────────────────
log "Installing to /Applications/Winshrink.app ..."
pkill -x Winshrink 2>/dev/null || true
sleep 0.3
sudo rm -rf "/Applications/Winshrink.app"
sudo cp -R "$APP" "/Applications/Winshrink.app"
sudo chown -R "$USER:staff" "/Applications/Winshrink.app"
ok "Installed ✓"

# ── 8. LaunchAgent (auto-start at login) ─────────────────────────────────────
AGENTS="$HOME/Library/LaunchAgents"
PLIST="$AGENTS/com.winshrink.app.plist"
mkdir -p "$AGENTS"
cp "$BDIR/com.winshrink.app.plist" "$PLIST"
chmod 644 "$PLIST"
launchctl unload "$PLIST" 2>/dev/null || true
launchctl load -w "$PLIST" && ok "LaunchAgent loaded ✓" || warn "Could not load LaunchAgent."

# ── 9. Launch ─────────────────────────────────────────────────────────────────
log "Launching Winshrink..."
open "/Applications/Winshrink.app"

# ── 10. Done ──────────────────────────────────────────────────────────────────
echo ""
echo -e "${GRN}${BLD}╔════════════════════════════════════════════╗${RST}"
echo -e "${GRN}${BLD}║          Installation complete! 🪴          ║${RST}"
echo -e "${GRN}${BLD}╚════════════════════════════════════════════╝${RST}"
echo ""
echo -e "  ${BLD}Shortcuts:${RST}"
echo    "    Cmd Shift F      →  Full screen"
echo    "    Cmd Shift Left   →  Left half"
echo    "    Cmd Shift Right  →  Right half"
echo    "    Cmd Shift Up     →  Top half"
echo    "    Cmd Shift Down   →  Bottom half"
echo ""
echo -e "  ${YLW}${BLD}ACTION REQUIRED:${RST} Grant Accessibility permission in"
echo    "  System Settings → Privacy & Security → Accessibility → Enable Winshrink"
echo ""
echo "Press Enter to close this window."
read -r
