#!/bin/bash
# ═══════════════════════════════════════════════════════════════════════════════
#  Winshrink – Installer  (self-contained, no Apple Developer ID required)
#  Double-click this file, or run:  bash Winshrink-install.command
# ═══════════════════════════════════════════════════════════════════════════════
set -e

RED='\033[0;31m'; GRN='\033[0;32m'; YLW='\033[1;33m'
BLD='\033[1m';    RST='\033[0m'
log()  { echo -e "${BLD}[Winshrink]${RST} $*";         }
ok()   { echo -e "${GRN}[Winshrink]${RST} $*";         }
warn() { echo -e "${YLW}[Winshrink]${RST} $*";         }
err()  { echo -e "${RED}[Winshrink]${RST} $*" >&2;     }

echo ""
echo -e "${BLD}╔════════════════════════════════════════════╗${RST}"
echo -e "${BLD}║      Winshrink – Window Manager v1.0       ║${RST}"
echo -e "${BLD}╚════════════════════════════════════════════╝${RST}"
echo ""

# ── 1. macOS version ──────────────────────────────────────────────────────────
MACOS_MAJOR=$(sw_vers -productVersion | cut -d. -f1)
if [ "$MACOS_MAJOR" -lt 12 ] 2>/dev/null; then
    err "Requires macOS 12 (Monterey) or later. You have $(sw_vers -productVersion)."
    exit 1
fi
log "macOS $(sw_vers -productVersion) ✓"

# ── 2. Locate a compatible Swift compiler + SDK pair ─────────────────────────
# Problem: macOS 26 beta Command Line Tools ships MacOSX26.x.sdk (needs Swift 6.2)
# but the compiler bundled in that CLT release may still be Swift 6.1.x.
# Strategy:
#   a) If Xcode.app is installed, prefer its toolchain (compiler+SDK always match).
#   b) Otherwise hunt for a MacOSX15.x / MacOSX14.x SDK in CLT to pair with the
#      older compiler.
#   c) If neither works, bail with clear remediation instructions.

if ! xcrun --find swiftc &>/dev/null; then
    err "Xcode Command Line Tools not found."
    warn "Install with:  xcode-select --install  then re-run this installer."
    xcode-select --install 2>/dev/null || true
    exit 1
fi

# Detect SDK version xcrun would pick by default
DEFAULT_SDK=$(xcrun --show-sdk-path 2>/dev/null || true)
SDK_MAJOR=$(basename "$DEFAULT_SDK" .sdk | grep -oE '[0-9]+' | head -1 || echo "0")

XCODE_DEV=""
COMPAT_SDK=""

if [ "${SDK_MAJOR:-0}" -ge 26 ] 2>/dev/null; then
    warn "Beta macOS $SDK_MAJOR SDK detected — searching for a compatible toolchain..."

    # (a) Xcode.app — its xcrun picks a matched SDK regardless of CLT default
    for xd in /Applications/Xcode.app/Contents/Developer                /Applications/Xcode-beta.app/Contents/Developer; do
        local_swift="$xd/Toolchains/XcodeDefault.xctoolchain/usr/bin/swiftc"
        if [ -x "$local_swift" ]; then
            XCODE_DEV="$xd"
            log "Found Xcode toolchain: $xd"
            break
        fi
    done

    # (b) Stable SDK in CLT (macOS 15.x or 14.x — compatible with Swift 6.1.x)
    if [ -z "$XCODE_DEV" ]; then
        COMPAT_SDK=$(ls -d             /Library/Developer/CommandLineTools/SDKs/MacOSX15*.sdk             /Library/Developer/CommandLineTools/SDKs/MacOSX14*.sdk             2>/dev/null | sort -rV | head -1 || true)
        if [ -n "$COMPAT_SDK" ]; then
            log "Found compatible SDK: $COMPAT_SDK"
        fi
    fi

    # (c) Neither found — tell the user exactly what to do
    if [ -z "$XCODE_DEV" ] && [ -z "$COMPAT_SDK" ]; then
        err "Compiler/SDK mismatch: Swift 6.1.2 cannot use the macOS $SDK_MAJOR beta SDK."
        err ""
        warn "Option 1 – Install Xcode from the App Store (free, recommended):"
        warn "   open https://apps.apple.com/app/xcode/id497799835"
        warn "   Then re-run this installer."
        warn ""
        warn "Option 2 – Reset Command Line Tools to a stable release:"
        warn "   sudo rm -rf /Library/Developer/CommandLineTools"
        warn "   xcode-select --install"
        warn "   Then re-run this installer."
        exit 1
    fi
fi

# Report what we'll use
if [ -n "$XCODE_DEV" ]; then
    SWIFTC_VER=$(DEVELOPER_DIR="$XCODE_DEV" xcrun swiftc --version 2>&1 | head -1)
    log "Compiler: $SWIFTC_VER (Xcode) ✓"
elif [ -n "$COMPAT_SDK" ]; then
    SWIFTC_VER=$(xcrun swiftc --version 2>&1 | head -1)
    log "Compiler: $SWIFTC_VER ✓"
    log "SDK:      $COMPAT_SDK ✓"
else
    SWIFTC_VER=$(xcrun swiftc --version 2>&1 | head -1)
    log "Compiler: $SWIFTC_VER ✓"
fi

# ── 3. Temp build dir ─────────────────────────────────────────────────────────
BDIR=$(mktemp -d /tmp/winshrink_XXXXXX)
trap 'rm -rf "$BDIR"' EXIT
log "Build dir: $BDIR"

# ── 4. Extract embedded source files ─────────────────────────────────────────
log "Extracting embedded source files..."

base64 --decode > "$BDIR/main.swift" << 'ENDSRC'
